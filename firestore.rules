rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── マイナンバーアクセスログ（監査用・書き込み専用・変更/削除禁止） ──
    // 管理者がマイナンバーを表示・コピーした時の監査ログ。
    // 認証済みユーザーは作成・読み取り可能、ただし一度書かれたら変更・削除不可。
    match /myNumberAccessLogs/{logId} {
      allow read: if request.auth != null
        && request.auth.token.firebase.sign_in_provider != 'anonymous';
      allow create: if request.auth != null
        && request.auth.token.firebase.sign_in_provider != 'anonymous';
      allow update, delete: if false;
    }

    // ── 通常ユーザー（メール認証）: 全コレクション読み書き可 ──
    match /{document=**} {
      allow read, write: if request.auth != null
        && request.auth.token.firebase.sign_in_provider != 'anonymous';
    }

    // ── 匿名ユーザー（入社フォーム提出者）: form_submissions のみ ──
    match /form_submissions/{token} {
      allow read, write: if request.auth != null;
    }

    // ── 匿名ユーザー（退職届提出者）: resignation_submissions のみ ──
    match /resignation_submissions/{token} {
      allow read, write: if request.auth != null;
    }

    // ── 匿名ユーザー（プロフィール入力者）: profile_tokens 読み取り + profiles 書き込み ──
    match /profile_tokens/{token} {
      allow read: if request.auth != null;
    }

    match /profiles/{uid} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // ── 秘書タスク（member_tasks）──
    // 認証済みユーザーが読み書き可能（上位ワイルドカードルールでカバー済み）
    // セキュリティ強化時: メンバーは自分のタスクのみ読み取り + ステータス変更のみ可にする
    // match /member_tasks/{taskId} {
    //   allow read: if request.auth != null && resource.data.memberId == request.auth.uid;
    //   allow update: if request.auth != null && resource.data.memberId == request.auth.uid
    //     && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status','updatedAt']);
    //   allow create, delete: if request.auth != null
    //     && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    // }

    // ── ガントチャート設定（判断待ち・フォーカス）: リーダー以上のみ読み取り ──
    // 【管轄】AIKATA（会社経営AI）が書き込む。decisions・focus_may の2ドキュメントのみ。
    // 【更新方法】AIKATAが update_gantt_example.mjs を参考にFirestoreへ直接書き込む。
    match /gantt_config/{docId} {
      allow read: if request.auth != null
        && request.auth.token.firebase.sign_in_provider != 'anonymous'
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'leader'];
      allow write: if request.auth != null
        && request.auth.token.firebase.sign_in_provider != 'anonymous'
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // ── ガントセクション: リーダー以上のみ読み取り ──
    // 【管轄】FORGEのseed_gantt.mjsスクリプト（Admin SDK）のみ書き込み可。
    // 【重要】クライアント側（AIKATA含む）からの書き込みは物理ブロック。
    //         Admin SDKはセキュリティルールをバイパスするため、seedスクリプトは引き続き動作する。
    match /gantt_sections/{sectionId} {
      allow read: if request.auth != null
        && request.auth.token.firebase.sign_in_provider != 'anonymous'
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'leader'];
      allow write: if false; // seedスクリプト（Admin SDK）のみ。クライアント側書き込み禁止
    }

    // ── ガント進捗オーバーレイ（gantt_progress）: AIKATAが書き込む ──
    // 【管轄】AIKATAのスクリプト（Admin SDK）が書き込む。seedを再実行してもここは消えない。
    // 【読み取り】リーダー以上のみ（gantt_sectionsと同じ権限）
    // 【書き込み】Admin SDKはルールをバイパスするため、クライアント側はadminのみ許可
    match /gantt_progress/{docId} {
      allow read: if request.auth != null
        && request.auth.token.firebase.sign_in_provider != 'anonymous'
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'leader'];
      allow write: if request.auth != null
        && request.auth.token.firebase.sign_in_provider != 'anonymous'
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // ── LINE Bot（認証なし）: allowed_dm_users 読み取り可 ──
    match /allowed_dm_users/{userId} {
      allow read: if true;
    }

    // ── アライアンスメンバー（認証なし）: attendance・shifts 読み取り可 ──
    match /attendance/{docId} {
      allow read, write: if true;
    }
    match /shifts/{docId} {
      allow read: if true; // アライアンスログイン画面での今週シフト取得
    }

    // ── LINE Bot（認証なし）: academy系コレクション読み書き可 ──
    match /academy_reports/{docId} {
      allow read, write: if true;
    }
    match /academy_users/{docId} {
      allow read, write: if true;
    }
    match /academy_roadmap/{docId} {
      allow read, write: if true;
    }
    match /academy_missions/{docId} {
      allow read, write: if true;
    }

    // ── 認証済みユーザー: users コレクション読み書き可 ──
    match /users/{userId} {
      allow read, write: if request.auth != null
        && request.auth.token.firebase.sign_in_provider != 'anonymous';
    }

    // ── アライアンスメンバー（認証なし）: users のうち isAlliance or noAuth のみ読み取り可 ──
    match /users/{userId} {
      allow read: if resource.data.isAlliance == true || resource.data.noAuth == true;
    }

  }
}
