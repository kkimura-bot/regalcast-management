rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── 通常ユーザー（メール認証）: 全コレクション読み書き可 ──
    match /{document=**} {
      allow read, write: if request.auth != null
        && request.auth.token.firebase.sign_in_provider != 'anonymous';
    }

    // ── 匿名ユーザー（入社フォーム提出者）: form_submissions のみ ──
    match /form_submissions/{token} {
      allow read, write: if request.auth != null;
    }

    // ── 匿名ユーザー（退職届提出者）: resignation_submissions のみ ──
    match /resignation_submissions/{token} {
      allow read, write: if request.auth != null;
    }

    // ── 匿名ユーザー（プロフィール入力者）: profile_tokens 読み取り + profiles 書き込み ──
    match /profile_tokens/{token} {
      allow read: if request.auth != null;
    }

    match /profiles/{uid} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // ── LINE Bot（認証なし）: allowed_dm_users 読み取り可 ──
    match /allowed_dm_users/{userId} {
      allow read: if true;
    }

    // ── アライアンスメンバー（認証なし）: attendance のみ読み書き可 ──
    match /attendance/{docId} {
      allow read, write: if true;
    }

    // ── LINE Bot（認証なし）: academy系コレクション読み書き可 ──
    match /academy_reports/{docId} {
      allow read, write: if true;
    }
    match /academy_users/{docId} {
      allow read, write: if true;
    }
    match /academy_roadmap/{docId} {
      allow read, write: if true;
    }
    match /academy_missions/{docId} {
      allow read, write: if true;
    }

    // ── 認証済みユーザー: users コレクション読み書き可 ──
    match /users/{userId} {
      allow read, write: if request.auth != null
        && request.auth.token.firebase.sign_in_provider != 'anonymous';
    }

    // ── アライアンスメンバー（認証なし）: users のうち isAlliance or noAuth のみ読み取り可 ──
    match /users/{userId} {
      allow read: if resource.data.isAlliance == true || resource.data.noAuth == true;
    }
  }
}
